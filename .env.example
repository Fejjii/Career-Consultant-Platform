# === LLM Provider ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Vector DB (Qdrant) ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=career_intel

# === Postgres ===
POSTGRES_DSN=postgresql+asyncpg://career:career@localhost:5432/career_intel

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Observability ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=career-intel-dev

# === Security ===
ADMIN_SECRET=change-me-in-production
RATE_LIMIT_RPM=30
MAX_INPUT_LENGTH=4000

# === Speech-to-text (optional overrides) ===
# MAX_SPEECH_FILE_BYTES=26214400
# SPEECH_ALLOWED_EXTENSIONS=wav,mp3,m4a,webm,mp4
# OPENAI_TRANSCRIPTION_MODEL=whisper-1
# SPEECH_TRANSCRIPTION_TIMEOUT_SECONDS=120

# === RAG / raw corpus (optional overrides) ===
# DATA_RAW_DIR=data/raw
# RAG_CHUNK_SIZE_TOKENS=400
# RAG_CHUNK_OVERLAP_TOKENS=80
# RAG_INITIAL_TOP_K=15
# RAG_TOP_K=5
# RAG_SIMILARITY_THRESHOLD=0.30
# RAG_WEAK_EVIDENCE_THRESHOLD=0.30
# RAG_STRONG_EVIDENCE_THRESHOLD=0.55
# RAG_EMBEDDING_BATCH_SIZE=64
# RAG_INGEST_DEBUG=false

# === Supplemental media (Streamlit UI only; not RAG) ===
# YouTube Data API v3 key for related videos in the sources panel (optional).
# YOUTUBE_DATA_API_KEY=...
# CAREER_INTEL_YOUTUBE_API_KEY=...

# === App ===
LOG_LEVEL=INFO
ENVIRONMENT=development
