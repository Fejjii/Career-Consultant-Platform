# === LLM Provider ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Vector DB (Qdrant) ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=career_intel

# === Postgres ===
POSTGRES_DSN=postgresql+asyncpg://career:career@localhost:5432/career_intel

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Observability ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=career-intel-dev

# === Security ===
ADMIN_SECRET=change-me-in-production
RATE_LIMIT_RPM=30
MAX_INPUT_LENGTH=4000

# === App ===
LOG_LEVEL=INFO
ENVIRONMENT=development
